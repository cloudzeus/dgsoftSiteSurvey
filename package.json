{
  "name": "softone-erp",
  "version": "1.0.0",
  "private": true,
  "description": "Softone ERP Integration Library — monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w softone-admin-dashboard",
    "build": "npm run db:generate -w softone-admin-dashboard && npm run build -w @softone/sync && npm run build -w softone-admin-dashboard",
    "start": "npm run start -w softone-admin-dashboard",
    "type-check": "npm run type-check --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:push": "npm run db:push -w softone-admin-dashboard",
    "db:seed": "npm run db:seed -w softone-admin-dashboard",
    "db:studio": "npm run db:studio -w softone-admin-dashboard"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "devDependencies": {
    "@swc/helpers": "^0.5.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "^0.27.7",
    "@esbuild/linux-x64": "^0.27.7",
    "lightningcss-darwin-arm64": "^1.32.0",
    "lightningcss-linux-x64-gnu": "^1.32.0"
  },
  "dependencies": {
    "next-intl": "^4.9.1",
    "puppeteer": "^24.40.0"
  }
}
