    "@types/sharp": "^0.31.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.0",
    "postcss": "^8.4.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
