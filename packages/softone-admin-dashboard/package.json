{
  "name": "softone-admin-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Softone ERP admin dashboard — Next.js 16, Tailwind 4.1, auth.js v5, shadcn/ui",
  "scripts": {
    "dev": "prisma generate && next dev --turbopack --port 3000",
    "build": "prisma generate && next build",
    "start": "sh start.sh",
    "type-check": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run",
    "db:push": "prisma db push && prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
