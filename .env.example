# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/dbname

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
AUTH_SECRET=generate-with-npx-auth-secret
AUTH_URL=https://your-production-domain.com
AUTH_TRUST_HOST=true
NEXTAUTH_SECRET=same-as-auth-secret
NEXTAUTH_URL=https://your-production-domain.com

# ─── Softone ERP ─────────────────────────────────────────────────────────────
SOFTONE_URL=https://yourserial.oncloud.gr
SOFTONE_USERNAME=
SOFTONE_PASSWORD=
SOFTONE_APP_ID=
SOFTONE_COMPANY=
SOFTONE_BRANCH=
SOFTONE_MODULE=
SOFTONE_REFID=

# ─── Bunny CDN ───────────────────────────────────────────────────────────────
BUNNY_ACCESS_KEY=
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_API_HOST=storage.bunnycdn.com
BUNNY_CDN_HOSTNAME=

# ─── Email (Mailgun) ─────────────────────────────────────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_ENDPOINT=https://api.eu.mailgun.net

# ─── Notifications ───────────────────────────────────────────────────────────
TEAMS_BOOKING_EMAILS=admin@yourdomain.com

# ─── Cron protection ─────────────────────────────────────────────────────────
CRON_SECRET=generate-a-random-secret

# ─── Site URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# ─── Optional: SMS (Yuboto) ──────────────────────────────────────────────────
YUBOTO_API_KEY=
YUBOTO_SENDER=

# ─── Optional: AI / Maps / Geocoding ─────────────────────────────────────────
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MAPTILER_API_KEY=
GEOCODE_API=
CLAID_API_KEY=
